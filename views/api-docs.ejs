<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>API Docs - <%= domain %></title>
    <meta name="description" content="A lightweight CDN server with a simple frontend & API."/>
    <link rel="icon" href="/icon/favicon.ico">
    <link rel="stylesheet" href="/css/styles.css"/>
    <meta name="robots" content="noindex, nofollow">
    <%- headTags || "" %>
  </head>
<body>
    <header>
        <div class="header-left"><%= domain %> - API Docs</div>
        <div class="header-right">
          <a href="/">Home</a>
          <a href="/logout">Logout</a>
        </div>
    </header>
    <main>
        <h2>API Endpoints</h2>
        <section>
            <h2>Authentication</h2>
            <p>All API routes require an API key to be passed in the <code>x-api-token</code> header.</p>
        </section>

        <section>
            <h2>Routes</h2>

            <article>
                <h3>POST /api/upload</h3>
                <p>Uploads a file to the server.</p>
                <h4>Headers</h4>
                <ul>
                    <li><code>x-api-token</code>: Your API key</li>
                </ul>
                <h4>Body</h4>
                <p>Form-data with a file field named <code>file</code>.</p>
                <h4>Response</h4>
                <pre>{ "success": true, "url": "<file_url>" }</pre>
            </article>

            <article>
                <h3>DELETE /api/:hash</h3>
                <p>Deletes a file or reverse share by its hash.</p>
                <h4>Headers</h4>
                <ul>
                    <li><code>x-api-token</code>: Your API key</li>
                </ul>
                <h4>Response</h4>
                <pre>{ "success": true, "type": "file" | "reverse-share" }</pre>
            </article>

            <article>
                <h3>POST /api/reverse-share</h3>
                <p>Creates a new reverse share.</p>
                <h4>Headers</h4>
                <ul>
                    <li><code>x-api-token</code>: Your API key</li>
                </ul>
                <h4>Body</h4>
                <p>JSON object with an optional <code>callbackUrl</code> field.</p>
                <h4>Response</h4>
                <pre>{ "success": true, "url": "<reverse_share_url>" }</pre>
            </article>

            <article>
                <h3>GET /api/:hash</h3>
                <p>Retrieves details about a reverse share by its hash.</p>
                <h4>Headers</h4>
                <ul>
                    <li><code>x-api-token</code>: Your API key</li>
                </ul>
                <h4>Response</h4>
                <pre>{
    "success": true,
    "used": true | false,
    "filename": "<filename>",
    "fileUrl": "<file_url>",
    "uploadedAt": "<timestamp>",
    "createdAt": "<timestamp>",
    "callbackUrl": "<callback_url>"
}</pre>
            </article>

            <article>
                <h3>POST /api/:hash</h3>
                <p>Uploads a file to a reverse share by its hash.</p>
                <h4>Body</h4>
                <p>Form-data with a file field named <code>file</code>.</p>
                <h4>Response</h4>
                <pre>{ "success": true, "fileUrl": "<file_url>", "filename": "<filename>", "uploadedAt": "<timestamp>" }</pre>
            </article>

            <article>
                <h3>GET /api/list</h3>
                <p>Lists all uploaded files.</p>
                <h4>Headers</h4>
                <ul>
                    <li><code>x-api-token</code>: Your API key</li>
                </ul>
                <h4>Response</h4>
                <pre>{ "success": true, "uploads": [<file_objects>] }</pre>
            </article>

            <article>
                <h3>GET /api/list/reverse-shares</h3>
                <p>Lists all reverse shares.</p>
                <h4>Headers</h4>
                <ul>
                    <li><code>x-api-token</code>: Your API key</li>
                </ul>
                <h4>Response</h4>
                <pre>{ "success": true, "uploads": [<reverse_share_objects>] }</pre>
            </article>
        </section>
    </main>
</body>
</html>